<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="440.0" prefWidth="620.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.knightsproblem2.PrimaryController">
    <children>
        <VBox layoutX="40.0" layoutY="36.0" spacing="14.0" prefWidth="540.0">
            <children>
                <Label text="Knight's Tour"
                       style="-fx-font-size: 22px; -fx-font-weight: bold;" />
                <Label wrapText="true" prefWidth="540.0"
                       text="The knight has to visit every square exactly once. Enter the board size and where it should start." />

                <HBox spacing="12.0" alignment="CENTER_LEFT">
                    <children>
                        <Label text="Board size (n)" prefWidth="110.0" />
                        <TextField fx:id="tfDim" text="8" prefWidth="80.0" />
                    </children>
                </HBox>
                <HBox spacing="12.0" alignment="CENTER_LEFT">
                    <children>
                        <Label text="Start row" prefWidth="110.0" />
                        <TextField fx:id="tfStartRow" text="0" prefWidth="80.0" />
                        <Label text="Start col" />
                        <TextField fx:id="tfStartCol" text="0" prefWidth="80.0" />
                    </children>
                </HBox>

                <Button mnemonicParsing="false" onAction="#solveTour"
                        prefHeight="40.0" prefWidth="160.0" text="Solve" />

                <Label fx:id="lblStatus" wrapText="true" prefWidth="540.0"
                       text="Note: no tour on 2x2, 3x3 or 4x4 boards." />
            </children>
        </VBox>
    </children>
</AnchorPane>
